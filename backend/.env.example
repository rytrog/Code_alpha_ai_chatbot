# ══════════════════════════════════════════════════
# University AI Chatbot — Environment Configuration
# Copy this file to .env and set your values
# ══════════════════════════════════════════════════

# ── App ──
APP_NAME=University AI Chatbot
DEBUG=false
HOST=0.0.0.0
PORT=8000

# ── PostgreSQL ──
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/university_ai

# ── LLM AI Configuration ──
# Supported providers: "gemini", "openai", "anthropic", "openai_compatible"
LLM_PROVIDER=gemini
LLM_MODEL=gemini-2.5-flash
LLM_API_KEY=SET_YOUR_GEMINI_API_KEY_HERE
LLM_BASE_URL=

# Legacy configuration fallbacks
GEMINI_API_KEY=SET_YOUR_GEMINI_API_KEY_HERE
GEMINI_MODEL=gemini-2.5-flash

# ── Rate Limiting ──
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=3600

# ── Chat ──
MAX_MESSAGE_LENGTH=500
MAX_ANSWER_WORDS=200

# ── Logging ──
LOG_LEVEL=INFO
